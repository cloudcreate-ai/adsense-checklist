# AI 分析配置（兼容 OpenAI API 格式的服务）
# 支持: DeepSeek, OpenAI, 月之暗面, Claude, 本地 LLM 等

# ============================================
# 全局默认配置（回退值）
# ============================================

# API Key（必填，启用 AI 分析）
AI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# API 地址（可选，默认 DeepSeek）
# DeepSeek:  https://api.deepseek.com
# OpenAI:    https://api.openai.com
# 月之暗面:  https://api.moonshot.cn
# Claude:    https://api.anthropic.com
AI_API_BASE=https://api.deepseek.com

# 通用模型名称（可选）
# AI_MODEL=deepseek-chat

# ============================================
# 两级 AI 模型配置
# ============================================
# Fast 模型：per-page 四维评分分析（批量调用，推荐便宜/快速的模型）
# Expert 模型：最终审核通过概率评估（仅调用 1 次，推荐更强的模型）
# 每个层级可独立配置模型、API 地址和 Key，支持不同厂商

# --- Fast 层 ---
AI_FAST_MODEL=deepseek-chat
# AI_FAST_API_BASE=https://api.deepseek.com
# AI_FAST_API_KEY=sk-xxxxxxxxx

# --- Expert 层 ---
AI_EXPERT_MODEL=claude-sonnet-4-6
# AI_EXPERT_API_BASE=https://api.anthropic.com
# AI_EXPERT_API_KEY=sk-ant-xxxxxxxxx

# 专家模式开关（CLI --expert 或使用环境变量默认值）
# 未打开时：只显示机械推算 + fast 模型 per-page 分析
# 打开后：额外调用 expert 模型做最终总结
# EXPERT_MODE=false

# 回退链:
#   AI_FAST_MODEL   → AI_MODEL → deepseek-chat
#   AI_FAST_API_BASE → AI_API_BASE → https://api.deepseek.com
#   AI_FAST_API_KEY  → AI_API_KEY
#   AI_EXPERT_MODEL   → AI_MODEL → claude-sonnet-4-6
#   AI_EXPERT_API_BASE → AI_API_BASE → https://api.anthropic.com
#   AI_EXPERT_API_KEY  → AI_API_KEY
