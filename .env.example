# AI 分析配置（兼容 OpenAI API 格式的服务）
# 支持: DeepSeek, OpenAI, 月之暗面, 本地 LLM 等

# API Key（必填，启用 AI 分析）
AI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# API 地址（可选，默认 DeepSeek）
# DeepSeek:  https://api.deepseek.com
# OpenAI:    https://api.openai.com
# 月之暗面:  https://api.moonshot.cn
AI_API_BASE=https://api.deepseek.com

# ============================================
# 两级 AI 模型配置
# ============================================
# Fast 模型：用于 per-page 四维评分分析（批量调用，推荐便宜/快速的模型）
# Expert 模型：用于最终审核通过概率评估（仅调用 1 次，推荐更强的模型）
# 如果未设置，两者都回退到 AI_MODEL

# Fast 模型（默认 deepseek-chat）
# AI_FAST_MODEL=deepseek-chat

# Expert 模型（默认 claude-sonnet-4-6）
# AI_EXPERT_MODEL=claude-sonnet-4-6

# 通用模型名称（可选，作为 fast 和 expert 的回退默认值）
# AI_MODEL=deepseek-chat
